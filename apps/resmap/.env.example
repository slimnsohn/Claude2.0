# Postgres system of record (local PostgreSQL 16 — see _docs/SETUP_WINDOWS.md)
DATABASE_URL=postgresql://resmap:resmap@localhost:5432/resmap
TEST_DATABASE_URL=postgresql://resmap:resmap@localhost:5432/resmap_test

# Postgres superuser password (set during winget install; admin ops only)
PGSUPERPASSWORD=

# LLM extraction runs through the `claude -p` CLI (Max plan) — no API key needed
CLAUDE_CLI_MODEL=sonnet

# Local control server token (the "Refresh data now" button on the Control page).
# Defaults to 'resmap_local_control' if unset. Localhost-only — set a real value
# before exposing the control server (port 8078) to any network.
RESMAP_CONTROL_TOKEN=resmap_local_control

# Kalshi (RSA-PSS key pair auth — regenerate at kalshi.com → account → API keys)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private.pem

# Polymarket — public reads need no key
